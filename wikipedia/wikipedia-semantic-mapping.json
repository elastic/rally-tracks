{
  "settings": {
    "index.number_of_replicas": {{ number_of_replicas | default(0) }},
    "index.number_of_shards": {{ number_of_shards | default(1) }}
  },
  "mappings": {
    "properties": {
      "title": {
        "type": "text",
        "copy_to": [
          "title_semantic"
        ]
      },
      "title_semantic": {
        "type": "semantic_text"
      },
      "content": {
        "type": "semantic_text",
        "copy_to": [
          "title_semantic"
        ]
      },
      "content_semantic": {
        "type": "semantic_text"
      },
      "namespace": {
        "ignore_above": 1024,
        "type": "keyword"
      },
      "redirect": {
        "ignore_above": 1024,
        "type": "keyword"
      }
    }
  }
}
