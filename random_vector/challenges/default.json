{%- set _vp_raw = visit_percentages | default("") | string | trim -%}
{%- if _vp_raw -%}
{%- set _vp_list = _vp_raw.split(",") | map("trim") | map("int") | list -%}
{%- else -%}
{%- set _vp_list = [rescore_oversample | default(-1) | int] -%}
{%- endif -%}
{%- set _multi_vp = _vp_list | length > 1 -%}
{
  "name": "index-and-search",
  "description": "Index documents with variable-sized partitions and benchmark filtered knn search per partition tier.",
  "default": true,
  "schedule": [
    {
      "name": "delete-data-stream",
      "operation": {
        "operation-type": "delete-data-stream",
        "data-stream": [
          "vectors-benchmark-random"
        ]
      }
    },
    {
      "name": "delete-templates",
      "operation": {
        "operation-type": "delete-composable-template"
      }
    },
    {
      "name": "create-templates",
      "operation": {
        "operation-type": "create-composable-template"
      }
    },
    {
      "name": "check-cluster-health",
      "operation": "check-cluster-health"
    },
    {
      "name": "random-indexing",
      "operation": "random-bulk-indexing",
      {%- if index_target_throughput is defined %}
      "target-throughput": {{ index_target_throughput | int }},
      {%- endif %}
      "clients": {{ index_clients | default(1) | int }},
      "iterations": {{ index_iterations | default(1000) | int }}
    },
    {
      "name": "refresh-after-index",
      "operation": {
        "operation-type": "refresh",
        "request-timeout": 1000,
        "include-in-reporting": true
      }
    },
    {# serverless-post-ingest-sleep-marker-start #}{%- if post_ingest_sleep|default(false) -%}
    {
      "name": "post-ingest-sleep-after-index",
      "operation": {
        "operation-type": "sleep",
        "duration": {{ post_ingest_sleep_duration|default(30) }}
      }
    },
    {%- endif -%}{# serverless-post-ingest-sleep-marker-end #}
    {
      "name": "wait-until-cluster-is-ready",
      "operation": "check-cluster-health"
    }{%- if small_partitions | default(100) | int > 0 -%}
    {%- for vp in _vp_list %},
    {
      "name": "small-partition-search{% if _multi_vp %}-vp{{ vp }}{% endif %}",
      "operation": "brute-force-filtered-search-small-partition{% if _multi_vp %}-vp{{ vp }}{% endif %}",
      "warmup-iterations": 500,
      "iterations": {{ search_iterations | default(10000) | int }},
      "clients": {{ search_clients | default(8) | int }}
    }
    {%- endfor -%}
    {%- endif -%}{%- if medium_partitions | default(20) | int > 0 -%}
    {%- for vp in _vp_list %},
    {
      "name": "medium-partition-search{% if _multi_vp %}-vp{{ vp }}{% endif %}",
      "operation": "brute-force-filtered-search-medium-partition{% if _multi_vp %}-vp{{ vp }}{% endif %}",
      "warmup-iterations": 500,
      "iterations": {{ search_iterations | default(10000) | int }},
      "clients": {{ search_clients | default(8) | int }}
    }
    {%- endfor -%}
    {%- endif -%}{%- if large_partitions | default(5) | int > 0 -%}
    {%- for vp in _vp_list %},
    {
      "name": "large-partition-search{% if _multi_vp %}-vp{{ vp }}{% endif %}",
      "operation": "brute-force-filtered-search-large-partition{% if _multi_vp %}-vp{{ vp }}{% endif %}",
      "warmup-iterations": 500,
      "iterations": {{ search_iterations | default(10000) | int }},
      "clients": {{ search_clients | default(8) | int }}
    }
    {%- endfor -%}
    {%- endif %}
  ]
}