    },

    {
      "name": "from_idx_limit_1_by_all_mapped_keyword_fields_limit_1",
      "operation-type": "esql",
      "query": "FROM idx_* | LIMIT 1 BY {{ wide_schema_limit_by_fields(n_indices) }} | LIMIT 1"
    },
    {
      "name": "from_idx_limit_1_by_all_mapped_keyword_fields_limit_100",
      "operation-type": "esql",
      "query": "FROM idx_* | LIMIT 1 BY {{ wide_schema_limit_by_fields(n_indices) }} | LIMIT 100"
    },
    {
      "name": "from_idx_limit_1_by_all_mapped_keyword_fields_limit_1000",
      "operation-type": "esql",
      "query": "FROM idx_* | LIMIT 1 BY {{ wide_schema_limit_by_fields(n_indices) }} | LIMIT 1000"
    },

    {
