{% set n_unmapped_fields = (n_unmapped_fields | default(998)) %}

{#
  keep(n) — emit a comma-separated KEEP field list: field_0, field_1, …, field_{n-1}
  Uses whitespace-trimming dashes so the macro output is a clean inline string.
#}
{%- macro keep(n) -%}
{%- for i in range(n) -%}
{%- if not loop.first %}, {% endif -%}field_{{ i }}
{%- endfor -%}
{%- endmacro -%}

{# ------------------------------------------------------------------ #}
{# Bulk-indexing operations (referenced only from the unmapped challenge) #}
{# ------------------------------------------------------------------ #}

    {
      "name": "index-unmapped-dense",
      "operation-type": "bulk",
      "indices": ["unmapped_bench_full_mapped_dense", "unmapped_bench_no_mapping_dense"],
      "bulk-size": {{bulk_size | default(500)}},
      "ingest-percentage": {{ingest_percentage | default(100)}}
    },
    {
      "name": "index-unmapped-sparse",
      "operation-type": "bulk",
      "indices": ["unmapped_bench_full_mapped_sparse", "unmapped_bench_no_mapping_sparse"],
      "bulk-size": {{bulk_size | default(500)}},
      "ingest-percentage": {{ingest_percentage | default(100)}}
    },

{# ------------------------------------------------------------------ #}
{# Query operations — 8 scenarios × 4 field counts × 2 densities = 64 #}
{# plus 4 focused cast probes and 16 targeted follow-up probes.        #}
{#                                                                      #}
{# Scenarios:                                                           #}
{#   mapped      — all fields in mapping, no SET needed                 #}
{#   mapped_load — all fields in mapping, SET unmapped_fields=load      #}
{#   mapped_source      — mapped baseline, project fields + _source      #}
{#   mapped_load_source — mapped + SET load, project fields + _source    #}
{#   nullify     — fully unmapped index, SET unmapped_fields=nullify    #}
{#   load        — fully unmapped index, SET unmapped_fields=load       #}
{#   mix_nullify — one mapped + one unmapped index, nullify             #}
{#   mix_load    — one mapped + one unmapped index, load                #}
{# Extra probes (outside field-count loop):                             #}
{#   mix_*_cast_field0_{dense,sparse} to validate cast-path behavior.   #}
{#   load_1field_2fe_* vs load_manyfields_2fe_* to test scaling with    #}
{#   two independent field extractions.                                  #}
{#   two realistic-ish mix/load query patterns (filter + sort).         #}
{#                                                                      #}
{# Trailing-comma rule: every operation gets a comma EXCEPT the very   #}
{# last one (sparse × allfields × mix_load).  We detect this with the  #}
{# captured d_last (outer-loop) + loop.last (inner-loop) pattern.      #}
{# ------------------------------------------------------------------ #}

{% set densities     = ["dense", "sparse"] %}
{% set field_configs = [(1, "1field"), (10, "10fields"), (100, "100fields"), (n_unmapped_fields, "allfields")] %}

{% for density in densities %}
{% set d_last = loop.last %}
{% for n, label in field_configs %}
    {
      "name": "unmapped_mapped_{{ label }}_{{ density }}",
      "operation-type": "esql",
      "query": "FROM unmapped_bench_full_mapped_{{ density }} | KEEP {{ keep(n) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_mapped_load_{{ label }}_{{ density }}",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_{{ density }} | KEEP {{ keep(n) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_mapped_source_{{ label }}_{{ density }}",
      "operation-type": "esql",
      "query": "FROM unmapped_bench_full_mapped_{{ density }} METADATA _source | KEEP {{ keep(n) }}, _source | LIMIT 1000"
    },
    {
      "name": "unmapped_mapped_load_source_{{ label }}_{{ density }}",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_{{ density }} METADATA _source | KEEP {{ keep(n) }}, _source | LIMIT 1000"
    },
    {
      "name": "unmapped_nullify_{{ label }}_{{ density }}",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_no_mapping_{{ density }} | KEEP {{ keep(n) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_load_{{ label }}_{{ density }}",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_no_mapping_{{ density }} | KEEP {{ keep(n) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_nullify_{{ label }}_{{ density }}",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_full_mapped_{{ density }}, unmapped_bench_no_mapping_{{ density }} | KEEP {{ keep(n) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_load_{{ label }}_{{ density }}",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_{{ density }}, unmapped_bench_no_mapping_{{ density }} | KEEP {{ keep(n) }} | LIMIT 1000"
    }{% if not (d_last and loop.last) %},{% endif %}

{% endfor %}
{% endfor %}

    ,
    {
      "name": "unmapped_mix_nullify_cast_field0_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_full_mapped_dense, unmapped_bench_no_mapping_dense | EVAL field_0_cast = TO_STRING(field_0) | KEEP field_0_cast | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_load_cast_field0_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_dense, unmapped_bench_no_mapping_dense | EVAL field_0_cast = TO_STRING(field_0) | KEEP field_0_cast | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_nullify_cast_field0_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_full_mapped_sparse, unmapped_bench_no_mapping_sparse | EVAL field_0_cast = TO_STRING(field_0) | KEEP field_0_cast | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_load_cast_field0_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_sparse, unmapped_bench_no_mapping_sparse | EVAL field_0_cast = TO_STRING(field_0) | KEEP field_0_cast | LIMIT 1000"
    },
    {
      "name": "unmapped_nullify_1field_2fe_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_no_mapping_dense | EVAL field_0_a = TO_STRING(field_0), field_0_b = CONCAT(field_0, \"\") | KEEP field_0_a, field_0_b | LIMIT 1000"
    },
    {
      "name": "unmapped_load_1field_2fe_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_no_mapping_dense | EVAL field_0_a = TO_STRING(field_0), field_0_b = CONCAT(field_0, \"\") | KEEP field_0_a, field_0_b | LIMIT 1000"
    },
    {
      "name": "unmapped_nullify_manyfields_2fe_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_no_mapping_dense | EVAL field_0_cast = TO_STRING(field_0), field_1_cast = TO_STRING(field_1) | KEEP {{ keep(100) }}, field_0_cast, field_1_cast | LIMIT 1000"
    },
    {
      "name": "unmapped_load_manyfields_2fe_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_no_mapping_dense | EVAL field_0_cast = TO_STRING(field_0), field_1_cast = TO_STRING(field_1) | KEEP {{ keep(100) }}, field_0_cast, field_1_cast | LIMIT 1000"
    },
    {
      "name": "unmapped_nullify_1field_2fe_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_no_mapping_sparse | EVAL field_0_a = TO_STRING(field_0), field_0_b = CONCAT(field_0, \"\") | KEEP field_0_a, field_0_b | LIMIT 1000"
    },
    {
      "name": "unmapped_load_1field_2fe_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_no_mapping_sparse | EVAL field_0_a = TO_STRING(field_0), field_0_b = CONCAT(field_0, \"\") | KEEP field_0_a, field_0_b | LIMIT 1000"
    },
    {
      "name": "unmapped_nullify_manyfields_2fe_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_no_mapping_sparse | EVAL field_0_cast = TO_STRING(field_0), field_1_cast = TO_STRING(field_1) | KEEP {{ keep(100) }}, field_0_cast, field_1_cast | LIMIT 1000"
    },
    {
      "name": "unmapped_load_manyfields_2fe_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_no_mapping_sparse | EVAL field_0_cast = TO_STRING(field_0), field_1_cast = TO_STRING(field_1) | KEEP {{ keep(100) }}, field_0_cast, field_1_cast | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_nullify_filter_keep_10fields_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_full_mapped_dense, unmapped_bench_no_mapping_dense | WHERE field_0 IS NOT NULL | KEEP {{ keep(10) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_load_filter_keep_10fields_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_dense, unmapped_bench_no_mapping_dense | WHERE field_0 IS NOT NULL | KEEP {{ keep(10) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_nullify_sort_keep_10fields_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_full_mapped_dense, unmapped_bench_no_mapping_dense | KEEP {{ keep(10) }} | SORT field_0 | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_load_sort_keep_10fields_dense",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_dense, unmapped_bench_no_mapping_dense | KEEP {{ keep(10) }} | SORT field_0 | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_nullify_filter_keep_10fields_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_full_mapped_sparse, unmapped_bench_no_mapping_sparse | WHERE field_0 IS NOT NULL | KEEP {{ keep(10) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_load_filter_keep_10fields_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_sparse, unmapped_bench_no_mapping_sparse | WHERE field_0 IS NOT NULL | KEEP {{ keep(10) }} | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_nullify_sort_keep_10fields_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"nullify\"; FROM unmapped_bench_full_mapped_sparse, unmapped_bench_no_mapping_sparse | KEEP {{ keep(10) }} | SORT field_0 | LIMIT 1000"
    },
    {
      "name": "unmapped_mix_load_sort_keep_10fields_sparse",
      "operation-type": "esql",
      "query": "SET unmapped_fields=\"load\"; FROM unmapped_bench_full_mapped_sparse, unmapped_bench_no_mapping_sparse | KEEP {{ keep(10) }} | SORT field_0 | LIMIT 1000"
    }
