{
  "name": "index-and-search",
  "description": "Index Wikipedia docs then run semantic or BM25 searches. Parameterize with model=(elser|jina|bm25).",
  "default": true,
  "schedule": [
    { "operation": "delete-index" },
    { "operation": "create-index" },
    { "operation": "check-cluster-health" },
    {
      "operation": {
        "name": "index-documents-en",
        "operation-type": "bulk",
        "bulk-size": {{ bulk_size | default(100) | int }},
        "ingest-percentage": {{ ingest_percentage | default(100) | float }}
      },
      "corpus": "wikipedia-en",
      "clients": {{ bulk_indexing_clients | default(1) | int }}
    },
    {
      "operation": {
        "name": "index-documents-es",
        "operation-type": "bulk",
        "bulk-size": {{ bulk_size | default(100) | int }},
        "ingest-percentage": {{ ingest_percentage | default(100) | float }}
      },
      "corpus": "wikipedia-es",
      "clients": {{ bulk_indexing_clients | default(1) | int }}
    },
    {
      "operation": {
        "name": "index-documents-dv",
        "operation-type": "bulk",
        "bulk-size": {{ bulk_size | default(100) | int }},
        "ingest-percentage": {{ ingest_percentage | default(100) | float }}
      },
      "corpus": "wikipedia-dv",
      "clients": {{ bulk_indexing_clients | default(1) | int }}
    },
    { "operation": "refresh-after-index" },
    { "operation": "force-merge" },
    { "operation": "refresh-after-merge" },
    {
      "operation": "search",
      "clients": {{ search_clients | default(1) | int }},
      "warmup-iterations": {{ search_warmup_iterations | default(50) | int }},
      "iterations": {{ search_iterations | default(500) | int }}
    }
  ]
},
{
  "name": "index-only",
  "description": "Index all three language corpora — use to measure ingest throughput and final index size.",
  "schedule": [
    { "operation": "delete-index" },
    { "operation": "create-index" },
    { "operation": "check-cluster-health" },
    {
      "operation": {
        "name": "index-documents-en",
        "operation-type": "bulk",
        "bulk-size": {{ bulk_size | default(100) | int }},
        "ingest-percentage": {{ ingest_percentage | default(100) | float }}
      },
      "corpus": "wikipedia-en",
      "clients": {{ bulk_indexing_clients | default(1) | int }}
    },
    {
      "operation": {
        "name": "index-documents-es",
        "operation-type": "bulk",
        "bulk-size": {{ bulk_size | default(100) | int }},
        "ingest-percentage": {{ ingest_percentage | default(100) | float }}
      },
      "corpus": "wikipedia-es",
      "clients": {{ bulk_indexing_clients | default(1) | int }}
    },
    {
      "operation": {
        "name": "index-documents-dv",
        "operation-type": "bulk",
        "bulk-size": {{ bulk_size | default(100) | int }},
        "ingest-percentage": {{ ingest_percentage | default(100) | float }}
      },
      "corpus": "wikipedia-dv",
      "clients": {{ bulk_indexing_clients | default(1) | int }}
    },
    { "operation": "refresh-after-index" },
    { "operation": "force-merge" },
    { "operation": "refresh-after-merge" }
  ]
}
