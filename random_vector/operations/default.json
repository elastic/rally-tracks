{
  "name": "check-cluster-health",
  "operation-type": "cluster-health",
  "request-params": {
    "wait_for_status": "green"
  },
  "retry-until-success": true,
  "include-in-reporting": true
},
{
  "name": "random-bulk-indexing",
  "operation-type": "bulk",
  "param-source": "random-bulk-param-source",
  "dims": {{ dims | default(128) | int }},
  "small-partitions": {{ small_partitions | default(100) | int }},
  "medium-partitions": {{ medium_partitions | default(20) | int }},
  "large-partitions": {{ large_partitions | default(5) | int }},
  "custom-routing": {{ custom_routing | default(false) | tojson }},
  "bulk-size": {{ index_bulk_size | default(1000) | int}},
  "paragraph-size": {{paragraph_size | default(1) | int}}
},
{
  "name": "brute-force-filtered-search",
  "operation-type": "search",
  "param-source": "knn-param-source",
  "dims": {{ dims | default(128) | int }},
  "small-partitions": {{ small_partitions | default(100) | int }},
  "medium-partitions": {{ medium_partitions | default(20) | int }},
  "large-partitions": {{ large_partitions | default(5) | int }},
  "rescore-oversample": {{ rescore_oversample | default(-1) | int }},
    {%- if paragraph_size | default(1) | int > 1 -%}
  "field": "nested.emb"
    {%- else %}
  "field": "emb"
    {%- endif %}
}
{%- set _vp_raw = visit_percentages | default("") | string | trim -%}
{%- if _vp_raw -%}
{%- set _vp_list = _vp_raw.split(",") | map("trim") | map("int") | list -%}
{%- else -%}
{%- set _vp_list = [rescore_oversample | default(-1) | int] -%}
{%- endif -%}
{%- set _multi_vp = _vp_list | length > 1 -%}
{%- for vp in _vp_list %},
{
  "name": "brute-force-filtered-search-small-partition{% if _multi_vp %}-vp{{ vp }}{% endif %}",
  "operation-type": "search",
  "param-source": "knn-param-source",
  "dims": {{ dims | default(128) | int }},
  "small-partitions": {{ small_partitions | default(100) | int }},
  "partition-tier": "small",
  "rescore-oversample": {{ vp }},
    {%- if paragraph_size | default(1) | int > 1 -%}
  "field": "nested.emb"
    {%- else %}
  "field": "emb"
    {%- endif %}
},
{
  "name": "brute-force-filtered-search-medium-partition{% if _multi_vp %}-vp{{ vp }}{% endif %}",
  "operation-type": "search",
  "param-source": "knn-param-source",
  "dims": {{ dims | default(128) | int }},
  "medium-partitions": {{ medium_partitions | default(20) | int }},
  "partition-tier": "medium",
  "rescore-oversample": {{ vp }},
    {%- if paragraph_size | default(1) | int > 1 -%}
  "field": "nested.emb"
    {%- else %}
  "field": "emb"
    {%- endif %}
},
{
  "name": "brute-force-filtered-search-large-partition{% if _multi_vp %}-vp{{ vp }}{% endif %}",
  "operation-type": "search",
  "param-source": "knn-param-source",
  "dims": {{ dims | default(128) | int }},
  "large-partitions": {{ large_partitions | default(5) | int }},
  "partition-tier": "large",
  "rescore-oversample": {{ vp }},
    {%- if paragraph_size | default(1) | int > 1 -%}
  "field": "nested.emb"
    {%- else %}
  "field": "emb"
    {%- endif %}
}
{%- endfor %}

