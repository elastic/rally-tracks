{% import "rally.helpers" as rally with context %}
{% set _base_url = (base_url | default( "https://rally-tracks.elastic.co/semantic_text_test")) %}
{
  "version": 2,
  "description": "Benchmark for tuning semantic_text bbq_disk options using Wikipedia data",
  "dependencies": [
    "pytrec_eval==0.5",
    "numpy"
  ],
  "indices": [
    {
      "name": "semantic-text-index",
      "body": "index-mapping.json"
    }
  ],
  "corpora": [
    {
      "name": "BeIR-dbpedia-entity",
      "base-url": "{{_base_url}}/beir-datasets/dbpedia/embeddings-jina-v5-small",
      "documents": [
        {
          "source-file": "corpus_embeddings.jsonl.bz2",
          "document-count": 1000,
          "compressed-bytes": 17813350,
          "uncompressed-bytes": 17813350
        }
      ]
    },
    {
      "name": "mteb-wikipedia-en",
      "base-url": "{{_base_url}}/mteb/WikipediaRetrievalMultilingual/en/embeddings-jina-v5-small",
      "documents": [
        {
          "source-file": "corpus_embeddings.jsonl.bz2",
          "document-count": 13500,
          "compressed-bytes": 1964368
        }
      ]
    },
    {
      "name": "mteb-wikipedia-fr",
      "base-url": "{{_base_url}}/mteb/WikipediaRetrievalMultilingual/fr/embeddings-jina-v5-small",
      "documents": [
        {
          "source-file": "corpus_embeddings.jsonl.bz2",
          "document-count": 1000,
          "compressed-bytes": 17813350,
          "uncompressed-bytes": 17813350
        }
      ]
    },
    {
      "name": "mteb-trec-covid",
      "base-url": "{{_base_url}}/mteb/trec-covid/embeddings-jina-v5-small",
      "documents": [
        {
          "source-file": "corpus_embeddings.jsonl.bz2",
          "document-count": 171332,
          "compressed-bytes": 45979367
        }
      ]
    }
  ],
  "operations": [
    {{ rally.collect(parts="operations/*.json") }}
  ],
  "challenges": [
    {{ rally.collect(parts="challenges/*.json") }}
  ]
}
