{% macro op_suffix(k, nc) -%}
{%- if k is none -%}default{%- else -%}{{ k }}{%- endif -%}-{%- if nc is none -%}default{%- else -%}{{ nc }}{%- endif -%}
{%- endmacro %}
{%- set p_search_ops = (search_ops | default([(None, None), (10, 15), (10, 50), (10, 100), (50, 100), (100, 150)])) %}
{
  "name": "create-index",
  "operation-type": "create-index",
  "settings": {{index_settings | default({}) | tojson}}
},
{
  "name": "check-cluster-health",
  "operation-type": "cluster-health",
  "request-params": {
    "wait_for_status": "green"
  },
  "retry-until-success": true
},
{
  "name": "index-append",
  "operation-type": "bulk",
  "corpora": {{ corpora | default(["msmarco-jina-10m"]) | tojson }},
  "bulk-size": {{bulk_size | default(500)}},
  "ingest-percentage": {{ingest_percentage | default(100)}}
},
{
  "name": "force-merge",
  "operation-type": "force-merge",
  "max-num-segments": {{ force_merge_max_num_segments | default(1) }},
  "request-timeout": {{ force_merge_timeout | default(7200) }},
  "include-in-reporting": true
},
{
  "name": "refresh-after-force-merge",
  "operation-type": "refresh",
  "request-timeout": 1000,
  "include-in-reporting": true
}
{%- for i in range(p_search_ops|length) %},
{
  "name": "knn-search-{{ op_suffix(p_search_ops[i][0], p_search_ops[i][1] if p_search_ops[i]|length > 1 else none) }}",
  "operation-type": "search",
  "param-source": "knn-param-source"
  {%- if p_search_ops[i][0] is not none %},
  "k": {{ p_search_ops[i][0] }}
  {%- endif %}
  {%- if p_search_ops[i]|length > 1 and p_search_ops[i][1] is not none %},
  "num-candidates": {{ p_search_ops[i][1] }}
  {%- endif %}
},
{
  "name": "knn-recall-{{ op_suffix(p_search_ops[i][0], p_search_ops[i][1] if p_search_ops[i]|length > 1 else none) }}",
  "operation-type": "knn-recall",
  "param-source": "knn-recall-param-source"
  {%- if p_search_ops[i][0] is not none %},
  "k": {{ p_search_ops[i][0] }}
  {%- endif %}
  {%- if p_search_ops[i]|length > 1 and p_search_ops[i][1] is not none %},
  "num-candidates": {{ p_search_ops[i][1] }}
  {%- endif %}
}
{%- endfor %}
