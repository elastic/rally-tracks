{# Multi-column LIMIT BY: FROM idx_* with BY spanning every field_<p>_* family present for this track (idx_0 → p=0; idx_i → p = i % 20). Uses the same n_fields as mappings (track default 500). #}
{% macro wide_schema_limit_by_fields(n_ix) -%}
{%- set nf = n_fields | default(500) -%}
{%- set w = namespace(first=true) -%}
{%- for p in range(0, 20) -%}
  {%- set pu = namespace(used=(p == 0)) -%}
  {%- for ii in range(1, n_ix) -%}
    {%- if (ii % 20) == p -%}
      {%- set pu.used = true -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if pu.used -%}
    {%- for j in range(0, nf) -%}
      {%- if not w.first -%}, {%- endif -%}field_{{ p }}_{{ j }}{%- set w.first = false -%}
    {%- endfor -%}
  {%- endif -%}
{%- endfor -%}
{%- endmacro %}

    {
      "name": "index-base",
      "operation-type": "bulk",
      "indices": [
        {% for i in range(1, n_indices) %}
        {% set idx_name = "idx_"+(i|string) %}
        "{{idx_name}}",
        {% endfor %}
        "idx_0"
      ],
      "bulk-size": {{bulk_size | default(10000)}},
      "ingest-percentage": {{ingest_percentage | default(100)}}
    },

    {
      "name": "from_idx_limit_1",
      "operation-type": "esql",
      "query": "FROM idx_* | limit 1"
    },
    {
      "name": "from_idx_limit_10",
      "operation-type": "esql",
      "query": "FROM idx_* | limit 10"
    },
    {
