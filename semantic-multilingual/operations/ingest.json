{
  "name": "delete-index",
  "operation-type": "delete-index",
  "include-in-reporting": false
},
{
  "name": "create-index",
  "operation-type": "create-index",
  "include-in-reporting": false
},
{
  "name": "check-cluster-health",
  "operation-type": "cluster-health",
  "request-params": { "wait_for_status": "green" },
  "retry-until-success": true,
  "include-in-reporting": false
},
{
  "name": "create-inference-endpoint",
  "operation-type": "raw-request",
  "path": "/_inference/{{ task_type | default('sparse_embedding') }}/semantic-multilingual-model",
  "method": "PUT",
  "body": {
    "service": "{{ inference_service | default('elser') }}",
    "service_settings": {
      "model_id": "{{ inference_model_id | default('.elser_model_2') }}",
      "num_allocations": {{ num_allocations | default(1) | int }},
      "num_threads": {{ num_threads | default(1) | int }}
    }
  },
  "request-timeout": 30000,
  "include-in-reporting": false
},
{
  "name": "delete-inference-endpoint",
  "operation-type": "raw-request",
  "path": "/_inference/{{ task_type | default('sparse_embedding') }}/semantic-multilingual-model",
  "method": "DELETE",
  "include-in-reporting": false,
  "ignore": 404
},
{
  "name": "index-documents",
  "operation-type": "bulk",
  "bulk-size": {{ bulk_size | default(100) | int }},
  "ingest-percentage": {{ ingest_percentage | default(100) | float }}
},
{
  "name": "refresh-after-index",
  "operation-type": "refresh",
  "request-timeout": 1800,
  "include-in-reporting": false
},
{
  "name": "force-merge",
  "operation-type": "force-merge",
  "max-num-segments": 1,
  "request-timeout": 36000,
  "include-in-reporting": false
},
{
  "name": "refresh-after-merge",
  "operation-type": "refresh",
  "include-in-reporting": false
}
